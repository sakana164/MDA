{
    "task": [
        {
            "name": "Advise",
            "label": "$task.Advise.label",
            "entry": "AdviseMain",
            "description": "$task.Advise.description",
            "option": [
                "NikkeAdvise",
                "EpisodeViewingReward"
            ],
            "group": [
                "daily"
            ]
        }
    ],
    "option": {
        "NikkeAdvise": {
            "type": "switch",
            "label": "$option.NikkeAdvise.label",
            "description": "$task.NikkeAdvise.description",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "NikkeEnterAdvise": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "EpisodeReward"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "NikkeEnterAdvise": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "EpisodeReward": {
            "type": "switch",
            "label": "$option.EpisodeReward.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EpisodeReward": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EpisodeReward": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "EpisodeViewingReward": {
            "type": "switch",
            "label": "$option.EpisodeViewingReward.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EpisodeViewing": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EpisodeViewing": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
