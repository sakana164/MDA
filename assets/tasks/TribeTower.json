{
    "task": [
        {
            "name": "TribeTower",
            "label": "$task.TribeTower.label",
            "entry": "TribeTowerMain",
            "description": "$task.TribeTower.description",
            "option": [
                "TribeTowerEnterCommonTower",
                "TribeTowerEnterElysionTower",
                "TribeTowerEnterMissilisTower",
                "TribeTowerEnterTetraTower",
                "TribeTowerEnterPilgrimTower"
            ],
            "group": [
                "daily"
            ]
        }
    ],
    "option": {
        "TribeTowerEnterCommonTower": {
            "type": "switch",
            "label": "$option.TribeTowerEnterCommonTower.label",
            "description": "$task.TribeTowerEnterCommonTower.Description",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "TribeTowerEnterCommonTower": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "TribeTowerEnterCommonTower": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "TribeTowerEnterElysionTower": {
            "type": "switch",
            "label": "$option.TribeTowerEnterElysionTower.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "TribeTowerEnterElysionTower": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "TribeTowerEnterElysionTower": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "TribeTowerEnterMissilisTower": {
            "type": "switch",
            "label": "$option.TribeTowerEnterMissilisTower.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "TribeTowerEnterMissilisTower": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "TribeTowerEnterMissilisTower": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "TribeTowerEnterTetraTower": {
            "type": "switch",
            "label": "$option.TribeTowerEnterTetraTower.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "TribeTowerEnterTetraTower": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "TribeTowerEnterTetraTower": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "TribeTowerEnterPilgrimTower": {
            "type": "switch",
            "label": "$option.TribeTowerEnterPilgrimTower.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "TribeTowerEnterPilgrimTower": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "TribeTowerEnterPilgrimTower": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
