{
    "CashShopMain": {
        "next": [
            "HallEnterCashShop",
            "[JumpBack]NavigationEnterHall"
        ]
    },
    "HallEnterCashShop": {
        "desc": "进入付费商店",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    358,
                    441,
                    59,
                    21
                ],
                "expected": [
                    "付费商店"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "CashShopCornerFlow",
            "HallEnterCashShop"
        ]
    },
    "CashShopCornerVisible": {
        "desc": "处于付费商店",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    15,
                    70,
                    25
                ],
                "expected": [
                    "付费商店"
                ]
            }
        }
    },
    "CashShopCornerFlow": {
        "desc": "处于付费商店",
        "next": [
            "CashShopCornerVisible",
            "[JumpBack]StepUpPackagePurchase",
            "ChooseOrdinaryPackage"
        ]
    },
    "StepUpPackagePurchase": {
        "desc": "购买StepUp礼包",
        "max_hit": 1,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    783,
                    389,
                    49,
                    28
                ],
                "expected": [
                    "免费"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "CommonConfirmReward"
        ]
    },
    "ChooseOrdinaryPackage": {
        "desc": "选择普通礼包",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1,
                    138,
                    543,
                    44
                ],
                "template": [
                    "CashShop/OrdinaryPackage.png"
                ]
            }
        },
        "pre_wait_freezes": 500,
        "action": {
            "type": "Click"
        },
        "next": [
            "[JumpBack]CashShopClickRedDot",
            "[JumpBack]CommonConfirmReward",
            "BaseEndTask"
        ]
    },
    "CashShopRedDotVisible": {
        "desc": "红点可见",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    9,
                    187,
                    509,
                    91
                ],
                "template": [
                    "Common/RedDot.png"
                ],
                "order_by": "Vertical",
                "index": -1
            }
        }
    },
    "CashShopClickRedDot": {
        "desc": "点击红点",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "CashShopRedDotVisible"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 200
    }
