{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Maa Tools Test Cases",
    "description": "`maa-tools` 测试用例文件结构",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "configs",
        "cases"
    ],
    "properties": {
        "configs": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "resource",
                "controller"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "测试配置名称（可选）"
                },
                "resource": {
                    "oneOf": [
                        {
                            "type": "string",
                            "description": "资源服别，如 官服"
                        },
                        {
                            "type": "array",
                            "description": "资源服别列表，如 [\"官服\", \"B服\"]",
                            "minItems": 1,
                            "uniqueItems": true,
                            "items": {
                                "type": "string"
                            }
                        }
                    ]
                },
                "controller": {
                    "oneOf": [
                        {
                            "type": "string",
                            "description": "控制器类型，如 ADB / Win32 / PlayCover"
                        },
                        {
                            "type": "array",
                            "description": "控制器类型列表，如 [\"ADB\", \"Win32\"]",
                            "minItems": 1,
                            "uniqueItems": true,
                            "items": {
                                "type": "string"
                            }
                        }
                    ]
                }
            }
        },
        "cases": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/case"
            }
        }
    },
    "$defs": {
        "case": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "image",
                "hits"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "用例名称"
                },
                "image": {
                    "type": "string",
                    "pattern": "^[^\\\\/]+\\.[^\\\\/.]+$",
                    "description": "对应图片文件名（必须包含扩展名，如 xxx.png）"
                },
                "hits": {
                    "type": "array",
                    "description": "期望命中的节点列表；可为空数组表示不应命中",
                    "items": {
                        "$ref": "#/$defs/hitItem"
                    }
                }
            }
        },
        "hitItem": {
            "oneOf": [
                {
                    "type": "string",
                    "description": "仅校验节点命中，如 InWorld"
                },
                {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["node"],
                    "properties": {
                        "node": {
                            "type": "string",
                            "description": "节点名"
                        },
                        "box": {
                            "oneOf": [
                                {
                                    "$ref": "#/$defs/rect"
                                },
                                {
                                    "$ref": "#/$defs/rectMatrix"
                                }
                            ],
                            "description": "期望识别框，可写固定值 [x, y, width, height]，也可按 controller/resource 等矩阵环境配置不同值"
                        }
                    }
                }
            ]
        },
        "rect": {
            "type": "array",
            "description": "识别框 [x, y, width, height]",
            "prefixItems": [
                {
                    "type": "integer",
                    "minimum": 0
                },
                {
                    "type": "integer",
                    "minimum": 0
                },
                {
                    "type": "integer",
                    "minimum": 0
                },
                {
                    "type": "integer",
                    "minimum": 0
                }
            ],
            "minItems": 4,
            "maxItems": 4,
            "items": false
        },
        "rectMatrix": {
            "type": "object",
            "description": "按矩阵环境配置不同识别框，key 可对应 controller、resource，或 controller:resource / controller/resource 等组合键",
            "minProperties": 1,
            "propertyNames": {
                "type": "string"
            },
            "additionalProperties": {
                "$ref": "#/$defs/rect"
            }
        }
    }
}
